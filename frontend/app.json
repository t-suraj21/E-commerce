{
  "expo": {
    "name": "Tarun Kirana Store",
    "slug": "tarun-kirana-store",
    "icon": "./assets/icon.png",
    "scheme": [
      "tarun-kirana-store",
      "com.googleusercontent.apps.1079591731539-ba7ka2bfme8jbp49ioomrmum4lhpm6hs",
      "com.googleusercontent.apps.1079591731539-33k2hf1nc8357p3vpoopb53b9kcc0e9f"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "bundleIdentifier": "com.tarunkiranastore.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2E7D32"
      }
    },
    "android": {
      "package": "com.tarunkiranastore.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2E7D32"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8ad00a05-dc50-41d3-a94d-c8681c7e0682"
      }
    },
    "owner": "t_suraj21"
  }
}
